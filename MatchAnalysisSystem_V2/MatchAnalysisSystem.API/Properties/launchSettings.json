      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "applicationUrl": "http://localhost:5123"
    },
    "https": {
      "commandName": "Project",
      "launchBrowser": true,
      // 🚀 Burayı da boş string yapıyoruz
      "launchUrl": "",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "applicationUrl": "https://localhost:7138;http://localhost:5123"
    }
  }
