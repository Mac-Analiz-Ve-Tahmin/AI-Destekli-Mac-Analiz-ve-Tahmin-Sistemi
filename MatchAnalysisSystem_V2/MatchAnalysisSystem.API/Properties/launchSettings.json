    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:5200",
      "sslPort": 44300
    }
  },
  "profiles": {
    "http": {
      "commandName": "Project",
      "launchBrowser": true,
      // 🚀 SWAGGER KİLİDİNİ SİLİYORUZ: Adresi boş bırakarak doğrudan ana sayfayı tetikliyoruz
