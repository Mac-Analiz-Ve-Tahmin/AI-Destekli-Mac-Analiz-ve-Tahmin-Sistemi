{
  "openapi": "3.0.4",
  "info": {
    "title": "MatchAnalysisSystem.API",
    "version": "1.0"
  },
  "paths": {
    "/api/Match/add-team": {
      "post": {
        "tags": [
          "Match"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attack",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 1
            }
          },
          {
            "name": "defense",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Match/teams": {
      "get": {
        "tags": [
          "Match"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Match/predict": {
      "get": {
        "tags": [
          "Match"
        ],
        "parameters": [
          {
            "name": "homeTeamId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "awayTeamId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "homeTeamName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "awayTeamName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Match/add-match-history": {
      "post": {
        "tags": [
          "Match"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MatchHistoryInput"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/MatchHistoryInput"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/MatchHistoryInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Match/daily-fixtures": {
      "get": {
        "tags": [
          "Match"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MatchHistoryInput": {
        "type": "object",
        "properties": {
          "matchDate": {
            "type": "string",
            "format": "date-time"
          },
          "homeTeamId": {
            "type": "integer",
            "format": "int32"
          },
          "awayTeamId": {
            "type": "integer",
            "format": "int32"
          },
          "homeGoals": {
            "type": "integer",
            "format": "int32"
          },
          "awayGoals": {
            "type": "integer",
            "format": "int32"
          },
          "homeCorners": {
            "type": "integer",
            "format": "int32"
          },
          "awayCorners": {
            "type": "integer",
            "format": "int32"
          },
          "homeShotsOnTarget": {
            "type": "integer",
            "format": "int32"
          },
          "awayShotsOnTarget": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Match"
    }
  ]
}